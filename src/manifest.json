{
  "manifest_version": 3,
  "name": "PoliBaldeo",
  "version": "1.4.0",
  "description": "Asistente de Matriculación para ESPOL",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PoliBaldeo"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "windows",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.academico.espol.edu.ec/UI/Registros/MateriaPlanificada.aspx*"
      ],
      "js": [
        "content/content-scraper.js",
        "content/content-navigator.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}